{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-workflow-state.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-dangerous-actions.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-reminder.py\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-subagent-context.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/subagent-stop-guard.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-guard.py\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/trellis-notify.sh done 'Claude Code' '本轮已完成，等你继续'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact-save-state.py\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/trellis-notify.sh attention 'Claude Code' '需要你的处理'"
          }
        ]
      }
    ]
  },
  "skills": {
    "trellis-brainstorm": ".claude/skills/trellis-brainstorm/SKILL.md",
    "trellis-grill-me": ".claude/skills/trellis-grill-me/SKILL.md",
    "trellis-dev-strategy": ".claude/skills/trellis-dev-strategy/SKILL.md",
    "trellis-before-dev": ".claude/skills/trellis-before-dev/SKILL.md",
    "trellis-implement": ".claude/skills/trellis-implement/SKILL.md",
    "trellis-check": ".claude/skills/trellis-check/SKILL.md",
    "trellis-spec-review": ".claude/skills/trellis-spec-review/SKILL.md",
    "trellis-code-review": ".claude/skills/trellis-code-review/SKILL.md",
    "trellis-code-architecture-review": ".claude/skills/trellis-code-architecture-review/SKILL.md",
    "trellis-improve-codebase-architecture": ".claude/skills/trellis-improve-codebase-architecture/SKILL.md",
    "trellis-update-spec": ".claude/skills/trellis-update-spec/SKILL.md",
    "trellis-break-loop": ".claude/skills/trellis-break-loop/SKILL.md",
    "trellis-merge-review": ".claude/skills/trellis-merge-review/SKILL.md",
    "trellis-finish-work": ".claude/skills/trellis-finish-work/SKILL.md"
  },
  "permissions": {
    "allow": [
      "Bash(python3 ./.trellis/scripts/*)",
      "Bash(python3 .claude/hooks/*)",
      "Bash(python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/*\")",
      "Bash(.claude/hooks/trellis-notify.sh *)",
      "Bash(\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/trellis-notify.sh *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "WebSearch",
      "WebFetch"
    ]
  }
}
